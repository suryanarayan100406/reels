PORT=3000
DATABASE_PATH=server/data/app.db

# Authentication
# Replace with a long, secure random string for session signing
SESSION_SECRET=your_secure_random_string

# Instagram oEmbed API Setup
# Create an App in Meta for Developers (https://developers.facebook.com/)
# Add the "oEmbed Read" product to the app
# Find these values in App Settings > Basic
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
