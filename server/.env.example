PORT=3000

# Authentication
SESSION_SECRET=your_secure_random_string

# Instagram oEmbed API (optional — app works without these)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# Turso Database (required for Vercel deployment, leave empty for local SQLite)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# CORS (set to your Vercel URL in production)
CORS_ORIGIN=http://localhost:5173
